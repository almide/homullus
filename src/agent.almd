// agent — single-turn query + tool loop
//
// One user input → one or more LLM calls. While the LLM returns
// tool_calls, we execute them under the permission resolver, feed the
// results back as role:"tool" messages, and re-call. When the LLM
// returns plain text, the provider is responsible for surfacing it
// (streaming providers print as deltas arrive; non-streaming providers
// print the assembled content once).
//
// The LLM call itself is injected: callers pass any function with the
// shape (model, msgs, opts) -> Result[LLMResponse, String]. Production
// uses `streaming_provider` (live token output for openai/openrouter/
// groq, falls back to `call_retry` + one-shot print for the rest);
// tests use a scripted provider that doesn't print.

import almai
import io
import json

import self.tools as ftools
import self.permission as perm
import self.compact as compactor

let MAX_TOOL_ROUNDS = 12

// Mirror of almai.Usage so we can construct it locally (almide
// disallows qualified-name record construction `almai.Usage { ... }`).
// Structurally identical → assignable to/from almai.Usage.
type Usage = {
  prompt_tokens: Int,
  completion_tokens: Int,
  total_tokens: Int,
}

// What a single REPL turn produces back to the caller: the updated
// conversation history plus the cumulative token usage from every LLM
// call that fired during the turn (a tool-using turn will have several).
type TurnResult = {
  history: List[almai.Message],
  usage: Usage,
}

fn empty_usage() -> Usage =
  Usage { prompt_tokens: 0, completion_tokens: 0, total_tokens: 0 }

fn add_usage(a: Usage, b: Usage) -> Usage =
  Usage {
    prompt_tokens: a.prompt_tokens + b.prompt_tokens,
    completion_tokens: a.completion_tokens + b.completion_tokens,
    total_tokens: a.total_tokens + b.total_tokens,
  }

fn supports_streaming(model: String) -> Bool =
  string.starts_with(model, "openai/") or
  string.starts_with(model, "openrouter/") or
  string.starts_with(model, "groq/") or
  string.starts_with(model, "anthropic/")

// Production provider. Streams text deltas to stdout for the
// OpenAI-shaped providers; for the rest, runs `call_retry` and prints
// the final content once. Either way, the returned LLMResponse carries
// the full assembled content + tool_calls (so the agent loop can keep
// dispatching tools).
effect fn streaming_provider(
  model: String,
  msgs: List[almai.Message],
  opts: almai.CallOptions,
) -> Result[almai.LLMResponse, String] =
  if supports_streaming(model) then
    almai.call_streaming(model, msgs, opts, (delta) => io.print(delta))
  else
    match almai.call_retry(model, msgs, opts, 3) {
      err(e) => err(e)
      ok(r)  => {
        if r.content != "" then io.print(r.content) else ()
        ok(r)
      }
    }

// Kept as an alias so older callers / tests still compile.
effect fn default_provider(
  model: String,
  msgs: List[almai.Message],
  opts: almai.CallOptions,
) -> Result[almai.LLMResponse, String] =
  almai.call_retry(model, msgs, opts, 3)

// Native tool roundtrip: feed the tool result back as role:"tool" with
// the call id, so providers (OpenAI / Anthropic) correlate it with the
// assistant's tool_use block.
fn make_tool_feedback(call: almai.ToolCall, output: String, is_error: Bool) -> almai.Message = {
  let body = if is_error then "ERROR: ${output}" else output
  almai.tool_result(call.id, body)
}

effect fn execute_tool(mode: String, call: almai.ToolCall) -> Result[(String, Bool), String] = {
  let args_json = call.arguments
  let allowed = perm.check(mode, call.name, args_json)
  if not allowed then
    ok(("permission denied by user", true))
  else
    match json.parse(args_json) {
      err(e) => ok(("invalid tool arguments: ${e}", true))
      ok(args) => match ftools.dispatch(call.name, args) {
        ok(s)  => ok((s, false))
        err(e) => ok((e, true))
      }
    }
}

effect fn print_text(content: String) -> Unit =
  if content == "" then ()
  else println(content)

effect fn print_tool_call(call: almai.ToolCall) -> Unit =
  println("\x1b[2m[${call.name}] ${string.take(call.arguments, 200)}\x1b[0m")

effect fn print_tool_result(call: almai.ToolCall, output: String, is_error: Bool) -> Unit = {
  let preview = string.take(output, 300)
  let suffix = if string.len(output) > 300 then "..." else ""
  let tag = if is_error then "ERROR: " else ""
  println("\x1b[2m[${call.id}] ${tag}${preview}${suffix}\x1b[0m")
}

effect fn process_calls(
  calls: List[almai.ToolCall],
  acc: List[almai.Message],
  mode: String,
) -> Result[List[almai.Message], String] =
  match list.first(calls) {
    none => ok(acc)
    some(call) => {
      print_tool_call(call)
      let exec = execute_tool(mode, call)!
      let output = exec.0
      let is_err = exec.1
      print_tool_result(call, output, is_err)
      let next = acc + [make_tool_feedback(call, output, is_err)]
      process_calls(list.drop(calls, 1), next, mode)
    }
  }

effect fn loop_round(
  call: (String, List[almai.Message], almai.CallOptions) -> Result[almai.LLMResponse, String],
  model: String,
  msgs: List[almai.Message],
  opts: almai.CallOptions,
  mode: String,
  round: Int,
  usage_so_far: Usage,
) -> Result[TurnResult, String] =
  if round >= MAX_TOOL_ROUNDS then {
    println("\x1b[31m[agent] max tool rounds reached (${int.to_string(MAX_TOOL_ROUNDS)}); stopping\x1b[0m")
    ok(TurnResult { history: msgs, usage: usage_so_far })
  } else
    match call(model, msgs, opts) {
      err(e) => {
        println("\x1b[31mError: ${e}\x1b[0m")
        ok(TurnResult { history: msgs, usage: usage_so_far })
      }
      ok(r) => {
        // Provider has already printed (streamed deltas or one-shot
        // for non-streamers). Add a trailing newline so the next REPL
        // event isn't glued to the assistant's last line.
        if r.content != "" then println("") else ()
        let new_usage = add_usage(usage_so_far, r.usage)
        // Preserve tool_calls on the assistant message so the next turn
        // sees a proper tool_use → tool_result roundtrip.
        let with_assistant = if list.is_empty(r.tool_calls) then
          msgs + [almai.assistant(r.content)]
        else
          msgs + [almai.assistant_with_tools(r.content, r.tool_calls)]
        if list.is_empty(r.tool_calls) then
          ok(TurnResult { history: with_assistant, usage: new_usage })
        else {
          let next = process_calls(r.tool_calls, with_assistant, mode)!
          loop_round(call, model, next, opts, mode, round + 1, new_usage)
        }
      }
    }

effect fn run_turn(
  call: (String, List[almai.Message], almai.CallOptions) -> Result[almai.LLMResponse, String],
  model: String,
  history: List[almai.Message],
  system_prompt: String,
  mode: String,
  input: String,
  compact_threshold: Int,
) -> Result[TurnResult, String] = {
  let with_user = history + [almai.user(input)]
  // Auto-compact ahead of the LLM call so we never blow the context limit.
  let compacted = compactor.compact(call, model, with_user, compact_threshold)!
  let opts = almai.defaults()
    |> almai.with_max_tokens(8192)
    |> almai.with_system(system_prompt)
    |> almai.with_tools(ftools.definitions())
  loop_round(call, model, compacted, opts, mode, 0, empty_usage())
}
