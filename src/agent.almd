// agent — single-turn query + tool loop
//
// One user input → one or more LLM calls.
// While the model returns tool_calls, we execute them under the
// permission resolver, append the results as user messages, and
// re-call. When the model returns plain text, we surface it.

import almai
import json

import self.tools as ftools
import self.permission as perm

let MAX_TOOL_ROUNDS = 12

// Native tool roundtrip: feed the tool result back as role:"tool" with
// the call id, so providers (OpenAI / Anthropic) correlate it with the
// assistant's tool_use block.
fn make_tool_feedback(call: almai.ToolCall, output: String, is_error: Bool) -> almai.Message = {
  let body = if is_error then "ERROR: ${output}" else output
  almai.tool_result(call.id, body)
}

effect fn execute_tool(mode: String, call: almai.ToolCall) -> (String, Bool) = {
  let args_json = call.arguments
  if not perm.check(mode, call.name, args_json) then
    ("permission denied by user", true)
  else
    match json.parse(args_json) {
      err(e) => ("invalid tool arguments: ${e}", true)
      ok(args) => match ftools.dispatch(call.name, args) {
        ok(s)  => (s, false)
        err(e) => (e, true)
      }
    }
}

effect fn print_text(content: String) -> Unit =
  if content == "" then ()
  else println(content)

effect fn print_tool_call(call: almai.ToolCall) -> Unit =
  println("\x1b[2m[${call.name}] ${string.take(call.arguments, 200)}\x1b[0m")

effect fn print_tool_result(call: almai.ToolCall, output: String, is_error: Bool) -> Unit = {
  let preview = string.take(output, 300)
  let suffix = if string.len(output) > 300 then "..." else ""
  let tag = if is_error then "ERROR: " else ""
  println("\x1b[2m[${call.id}] ${tag}${preview}${suffix}\x1b[0m")
}

effect fn process_calls(
  calls: List[almai.ToolCall],
  acc: List[almai.Message],
  mode: String,
) -> List[almai.Message] =
  match list.first(calls) {
    none => acc
    some(call) => {
      print_tool_call(call)
      let exec = execute_tool(mode, call)
      let output = exec.0
      let is_err = exec.1
      print_tool_result(call, output, is_err)
      let next = acc + [make_tool_feedback(call, output, is_err)]
      process_calls(list.drop(calls, 1), next, mode)
    }
  }

effect fn loop_round(
  model: String,
  msgs: List[almai.Message],
  opts: almai.CallOptions,
  mode: String,
  round: Int,
) -> List[almai.Message] =
  if round >= MAX_TOOL_ROUNDS then {
    println("\x1b[31m[agent] max tool rounds reached (${int.to_string(MAX_TOOL_ROUNDS)}); stopping\x1b[0m")
    msgs
  } else
    match almai.call_retry(model, msgs, opts, 3) {
      err(e) => {
        println("\x1b[31mError: ${e}\x1b[0m")
        msgs
      }
      ok(r) => {
        print_text(r.content)
        // Preserve tool_calls on the assistant message so the next turn
        // sees a proper tool_use → tool_result roundtrip.
        let with_assistant = if list.is_empty(r.tool_calls) then
          msgs + [almai.assistant(r.content)]
        else
          msgs + [almai.assistant_with_tools(r.content, r.tool_calls)]
        if list.is_empty(r.tool_calls) then with_assistant
        else {
          let next = process_calls(r.tool_calls, with_assistant, mode)
          loop_round(model, next, opts, mode, round + 1)
        }
      }
    }

effect fn run_turn(
  model: String,
  history: List[almai.Message],
  system_prompt: String,
  mode: String,
  input: String,
) -> List[almai.Message] = {
  let with_user = history + [almai.user(input)]
  let opts = almai.defaults()
    |> almai.with_max_tokens(8192)
    |> almai.with_system(system_prompt)
    |> almai.with_tools(ftools.definitions())
  loop_round(model, with_user, opts, mode, 0)
}
